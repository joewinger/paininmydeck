{
  "name": "paininmydeck",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:build": "storybook build",
    "build": "vite build",
    "build:staging": "CLOUDFLARE_ENV=staging vite build --mode staging",
    "build:production": "CLOUDFLARE_ENV=production vite build --mode production",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --config vitest.config.ts --project=unit",
    "test:watch": "vitest --config vitest.config.ts --project=unit",
    "test:storybook": "vitest run --config vitest.config.ts --project=storybook",
    "test:worker": "vitest run --config vitest.worker.config.ts",
    "test:e2e": "playwright test",
    "cf:types": "wrangler types",
    "cf:types:check": "wrangler types --check",
    "cf:startup": "wrangler check startup",
    "config:deploy:check": "node -e \"if (!process.env.VITE_TURNSTILE_SITE_KEY) { console.error('VITE_TURNSTILE_SITE_KEY is required for remote builds.'); process.exit(1) }\"",
    "deploy:staging": "npm run config:deploy:check && npm run build:staging && wrangler deploy",
    "deploy:production": "npm run config:deploy:check && npm run build:production && wrangler deploy",
    "deploy:dry-run": "npm run config:deploy:check && npm run build:production && wrangler deploy --dry-run"
  },
  "dependencies": {
    "interactjs": "1.10.27",
    "ionicons": "5.0.0",
    "normalize.css": "8.0.1",
    "pinia": "3.0.4",
    "vue": "3.5.39",
    "vue-router": "4.6.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.0",
    "@cloudflare/vitest-pool-workers": "0.18.5",
    "@cloudflare/workers-types": "5.20260715.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@storybook/addon-a11y": "10.5.0",
    "@storybook/addon-docs": "10.5.0",
    "@storybook/addon-vitest": "10.5.0",
    "@storybook/vue3-vite": "10.5.0",
    "@types/node": "24.10.1",
    "@types/pngjs": "6.0.5",
    "@vitejs/plugin-vue": "6.0.8",
    "@vitest/browser": "4.1.10",
    "@vitest/browser-playwright": "4.1.10",
    "@vue/test-utils": "2.4.11",
    "eslint": "10.7.0",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "pixelmatch": "7.2.0",
    "pngjs": "7.0.0",
    "prettier": "3.9.5",
    "sass": "1.101.0",
    "storybook": "10.5.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "vue-eslint-parser": "10.3.0",
    "vue-tsc": "3.3.7",
    "wrangler": "4.111.0"
  }
}
