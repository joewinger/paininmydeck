{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["./worker-configuration.d.ts"]
  },
  "include": [
    "worker/**/*.ts",
    "tests/worker/**/*.ts",
    "src/shared/**/*.ts",
    "worker-configuration.d.ts"
  ]
}
